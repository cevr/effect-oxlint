{
  "name": "oxlint-plugin-effect",
  "version": "0.2.0",
  "type": "module",
  "description": "oxlint plugin with Effect-specific lint rules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cevr/effect-oxlint"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      }
    },
    "./presets/*": {
      "import": {
        "types": "./dist/presets/*.d.ts",
        "default": "./dist/presets/*.js"
      }
    }
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "concurrently -n ox,effect -c yellow,blue \"oxlint\" \"bun run lint:effect\"",
    "lint:ox": "oxlint",
    "lint:effect": "effect-language-service diagnostics --project tsconfig.json --lspconfig \"$(cat .effect-lsp.json)\"",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "gate": "concurrently -n type,style,test -c blue,yellow,green \"bun run typecheck\" \"bun run lint\" \"bun run test\"",
    "codegen": "bun run scripts/codegen.ts",
    "add-rule": "bun run scripts/add-rule.ts"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.60.0"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.49"
  },
  "devDependencies": {
    "@effect/language-service": "latest",
    "@effect/vitest": "latest",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "concurrently": "latest",
    "effect": "4.0.0-beta.49",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsdown": "^0.21.7",
    "typescript": "latest",
    "vitest": "latest"
  }
}
