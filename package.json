{
  "name": "effect-oxlint",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": ["packages/oxlint-plugin-effect"],
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:ox": "oxlint",
    "test": "turbo run test",
    "build": "turbo run build",
    "gate": "concurrently -n type,lint,test -c blue,yellow,green \"turbo run typecheck\" \"turbo run lint\" \"turbo run test\"",
    "codegen": "bun run packages/oxlint-plugin-effect/scripts/codegen.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "concurrently": "latest",
    "lefthook": "latest",
    "turbo": "latest"
  }
}
